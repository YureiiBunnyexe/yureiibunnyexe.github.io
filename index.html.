<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Mi Landing Page</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(-45deg,#0f172a,#111827,#1e293b,#312e81);
    background-size:400% 400%;
    animation:gradient 15s ease infinite;
    color:white;
    overflow-x:hidden;
}

@keyframes gradient{
    0%{background-position:0% 50%;}
    50%{background-position:100% 50%;}
    100%{background-position:0% 50%;}
}

.container{
    width:100%;
    max-width:500px;
    padding:30px;
}

.card{
    backdrop-filter:blur(20px);
    background:rgba(255,255,255,.08);
    border:1px solid rgba(255,255,255,.15);
    border-radius:30px;
    padding:35px;
    text-align:center;
    box-shadow:0 15px 35px rgba(0,0,0,.35);
    animation:fadeUp 1s ease;
}

@keyframes fadeUp{
    from{
        opacity:0;
        transform:translateY(30px);
    }
    to{
        opacity:1;
        transform:translateY(0);
    }
}

.profile{
    width:130px;
    height:130px;
    border-radius:50%;
    object-fit:cover;
    border:4px solid rgba(255,255,255,.25);
    margin-bottom:15px;
}

h1{
    font-size:28px;
    margin-bottom:5px;
}

.bio{
    color:#d1d5db;
    font-size:14px;
    margin-bottom:30px;
}

.links{
    display:flex;
    flex-direction:column;
    gap:15px;
}

.link-btn{
    text-decoration:none;
    color:white;
    background:rgba(255,255,255,.08);
    border:1px solid rgba(255,255,255,.15);
    padding:16px;
    border-radius:15px;
    display:flex;
    align-items:center;
    justify-content:center;
    gap:12px;
    font-weight:500;
    transition:.3s;
}

.link-btn:hover{
    transform:translateY(-3px) scale(1.02);
    background:rgba(255,255,255,.15);
}

.link-btn i{
    font-size:20px;
}

.socials{
    margin-top:30px;
    display:flex;
    justify-content:center;
    gap:20px;
}

.socials a{
    color:white;
    font-size:24px;
    transition:.3s;
}

.socials a:hover{
    transform:translateY(-5px);
}

.footer{
    margin-top:25px;
    font-size:12px;
    color:#cbd5e1;
}

.glow{
    position:fixed;
    width:300px;
    height:300px;
    border-radius:50%;
    background:#4f46e5;
    filter:blur(120px);
    opacity:.25;
    z-index:-1;
}

.glow.one{
    top:-100px;
    left:-100px;
}

.glow.two{
    bottom:-100px;
    right:-100px;
}

@media(max-width:600px){

    .container{
        padding:20px;
    }

    .card{
        padding:25px;
    }

    h1{
        font-size:24px;
    }

}

</style>
</head>
<body>

<div class="glow one"></div>
<div class="glow two"></div>

<div class="container">

    <div class="card">

        <!-- FOTO DE PERFIL -->
        <img
        class="profile"
        src="https://i.pravatar.cc/300"
        alt="Perfil">

        <h1>Tu Nombre</h1>

        <p class="bio">
            Creador de contenido • Gaming • Sim Racing • Tecnología
        </p>

        <div class="links">

            <a class="link-btn" href="https://youtube.com" target="_blank">
                <i class="fab fa-youtube"></i>
                YouTube
            </a>

            <a class="link-btn" href="https://tiktok.com" target="_blank">
                <i class="fab fa-tiktok"></i>
                TikTok
            </a>

            <a class="link-btn" href="https://instagram.com" target="_blank">
                <i class="fab fa-instagram"></i>
                Instagram
            </a>

            <a class="link-btn" href="https://x.com" target="_blank">
                <i class="fab fa-x-twitter"></i>
                X / Twitter
            </a>

            <a class="link-btn" href="https://discord.com" target="_blank">
                <i class="fab fa-discord"></i>
                Discord
            </a>

            <a class="link-btn" href="https://twitch.tv" target="_blank">
                <i class="fab fa-twitch"></i>
                Twitch
            </a>

        </div>

        <div class="socials">

            <a href="https://youtube.com" target="_blank">
                <i class="fab fa-youtube"></i>
            </a>

            <a href="https://instagram.com" target="_blank">
                <i class="fab fa-instagram"></i>
            </a>

            <a href="https://tiktok.com" target="_blank">
                <i class="fab fa-tiktok"></i>
            </a>

            <a href="https://x.com" target="_blank">
                <i class="fab fa-x-twitter"></i>
            </a>

        </div>

        <div class="footer">
            © 2026 Tu Nombre
        </div>

    </div>

</div>

</body>
</html>
